#!/usr/bin/env bash
# Maki dynamic provider: Google Vertex AI (Gemini) via the NATIVE Gemini endpoint.
#
# Uses base "google" (not the OpenAI-compat shim) so Gemini 3.x thought signatures
# round-trip correctly on multi-turn tool calls. The OpenAI-compat layer drops the
# `extra_content.google.thought_signature` field, which breaks tool use after the
# first turn — the native generateContent format carries `thoughtSignature` as a
# first-class part, which Maki's google provider preserves.
#
# Auth uses Application Default Credentials (ADC) — no API key required. It honors
# GOOGLE_APPLICATION_CREDENTIALS (a service-account JSON) when set, otherwise the
# credentials from `gcloud auth application-default login`. A short-lived OAuth token
# is minted on every `resolve`, so token expiry is handled transparently.
#
# Configure project/region via the same env vars the `dc` alias uses:
#   GOOGLE_VERTEX_PROJECT  (default: kazoo-engineering)
#   GOOGLE_VERTEX_LOCATION (default: global)
set -euo pipefail

PROJECT="${GOOGLE_VERTEX_PROJECT:-kazoo-engineering}"
LOCATION="${GOOGLE_VERTEX_LOCATION:-global}"

if [ "$LOCATION" = "global" ]; then
  HOST="aiplatform.googleapis.com"
else
  HOST="${LOCATION}-aiplatform.googleapis.com"
fi
# Maki's `google` base appends `/models/<model>:streamGenerateContent` to this base_url,
# which lands exactly on Vertex's native publisher endpoint.
API_PATH="/v1beta1/projects/${PROJECT}/locations/${LOCATION}/publishers/google"
DIRECT_BASE="https://${HOST}${API_PATH}"

mint_token() {
  command -v gcloud >/dev/null 2>&1 || return 1
  gcloud auth application-default print-access-token 2>/dev/null \
    || gcloud auth print-access-token 2>/dev/null
}

auth_hint() {
  if ! command -v gcloud >/dev/null 2>&1; then
    echo "vertex provider: 'gcloud' not found. Install the Google Cloud SDK." >&2
  else
    echo "vertex provider: no credentials. Run 'gcloud auth application-default login'." >&2
  fi
}

case "${1:-}" in
  info)
    # Must stay well under Maki's ~5s discovery timeout, so do NO network here —
    # just report whether gcloud exists. Token minting happens lazily in `resolve`.
    if command -v gcloud >/dev/null 2>&1; then has_auth=true; else has_auth=false; fi
    printf '{"display_name":"Vertex AI (Gemini)","base":"google","has_auth":%s}\n' "$has_auth"
    ;;
  models)
    # Native Gemini model ids (no `google/` prefix — the google base appends
    # `/models/<id>:streamGenerateContent`).
    cat <<'EOF'
[
  {"id":"gemini-3.5-flash","tier":"medium","context_window":1048576,"max_output_tokens":65536},
  {"id":"gemini-2.5-flash","tier":"medium","context_window":1048576,"max_output_tokens":65536},
  {"id":"gemini-2.5-pro","tier":"strong","context_window":1048576,"max_output_tokens":65536}
]
EOF
    ;;
  resolve|refresh)
    token="$(mint_token)"
    if [ -z "$token" ]; then
      auth_hint
      exit 1
    fi
    # When sc launched the signature-preserving proxy, route through it so Gemini
    # 3.x multi-turn tool calls work; otherwise talk to Vertex directly.
    if [ -n "${VERTEX_PROXY_PORT:-}" ]; then
      base="http://127.0.0.1:${VERTEX_PROXY_PORT}${API_PATH}"
    else
      base="$DIRECT_BASE"
    fi
    printf '{"base_url":"%s","headers":{"Authorization":"Bearer %s"}}\n' "$base" "$token"
    ;;
  login)
    gcloud auth application-default login
    ;;
  logout)
    gcloud auth application-default revoke 2>/dev/null || true
    ;;
  *)
    echo "vertex provider: unknown subcommand '${1:-}'" >&2
    exit 1
    ;;
esac
