# Update this to `.secrets` and fill in things below if we have secrets we
# want in the environment.

# `sc` (Maki) talks to Gemini through Vertex AI — no API key needed. It mints a
# short-lived token from your gcloud login / Application Default Credentials.
# One-time setup:  gcloud auth application-default login
# To use a service-account JSON instead, point ADC at it:
# export GOOGLE_APPLICATION_CREDENTIALS="$HOME/path/to/service-account.json"
# Override project/region (defaults: kazoo-engineering / global):
# export GOOGLE_VERTEX_PROJECT="kazoo-engineering"
# export GOOGLE_VERTEX_LOCATION="global"
